. ./device

./mkbootimg.py \
--kernel $1 --ramdisk /dev/null \
--os_version "$kernel_os_version" \
--os_patch_level "$kernel_os_patch_level" \
--pagesize "$kernel_pagesize" \
--base "$kernel_base" \
--kernel_offset "$kernel_kernel_offset" \
--ramdisk_offset "$kernel_ramdisk_offset" \
--second_offset "$kernel_second_offset" \
--tags_offset "$kernel_tags_offset" \
--board "$kernel_board" \
--cmdline "$kernel_cmdline" \
-o $2
