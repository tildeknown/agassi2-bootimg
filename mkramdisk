. ./device

./mkbootimg.py \
--kernel /dev/null --ramdisk $1 \
--os_version "$ramdisk_os_version" \
--os_patch_level "$ramdisk_os_patch_level" \
--pagesize "$ramdisk_pagesize" \
--base "$ramdisk_base" \
--kernel_offset "$ramdisk_kernel_offset" \
--ramdisk_offset "$ramdisk_ramdisk_offset" \
--second_offset "$ramdisk_second_offset" \
--tags_offset "$ramdisk_tags_offset" \
--board "$ramdisk_board" \
--cmdline "$ramdisk_cmdline" \
-o $2
